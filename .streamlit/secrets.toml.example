# ============================================================
# Streamlit Cloud — Secrets configuration
# ============================================================
# 1. Sur Streamlit Cloud : va dans App Settings > Secrets
#    et colle le contenu ci-dessous (adapté avec ta vraie clé).
#
# 2. En local : ce fichier N'EST PAS utilisé.
#    Utilise plutôt le fichier .env à la racine du projet.
# ============================================================

GROQ_API_KEY = "gsk_..."

# Optionnel — modèle Groq à utiliser (défaut : llama-3.3-70b-versatile)
# GROQ_MODEL = "llama-3.3-70b-versatile"
